---
import Layout from "@/layouts/Layout.astro";
import EntryList from "@/components/EntryList";
import Profile from "@/components/Profile";
import Graph from "@/components/Graph";
import Tabs from "@/components/Tabs";
import { buildGraph } from "@/lib/graph";
import { indexKey, compareIndexKeys } from "@/lib/index-key";
import { iconFor } from "@/site.config";
import { getCollection } from "astro:content";

const scraps = await getCollection("scraps");
const entries = scraps.map((entry) => ({
  href: `/scraps/${entry.id}/`,
  icon: iconFor(entry.data.tags),
  title: entry.data.title,
}));
const graph = await buildGraph();
const indexKeys = await Promise.all(
  entries.map((entry) => indexKey(entry.title)),
);
const groups = Object.groupBy(entries, (_, i) => indexKeys[i]!);
const keys = Object.keys(groups).toSorted(compareIndexKeys);
---

<Layout title="Scraps">
  <Profile />
  <Tabs active="scraps" />
  <div class="px-4 py-3">
    <Graph client:visible graph={graph} />
  </div>
  {
    keys.map((key) => (
      <section>
        <h2 class="text-text-muted px-4 pt-4 pb-1 text-xl font-bold">{key}</h2>
        <EntryList entries={groups[key]!} />
      </section>
    ))
  }
</Layout>
