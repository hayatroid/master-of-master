---
import Badge from "@/components/Badge";
import EntryList from "@/components/EntryList";
import Graph from "@/components/Graph";
import PageHeader from "@/components/PageHeader";
import Layout from "@/layouts/Layout.astro";
import { buildGraph, subgraph, wikilinkTargets } from "@/lib/graph";
import { iconFor } from "@/site.config";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const scraps = await getCollection("scraps");
  return scraps.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const graph = subgraph(await buildGraph(), entry.id);

const articles = await getCollection("articles");
const references = articles
  .filter((article) => wikilinkTargets(article.body ?? "").includes(entry.id))
  .map((article) => ({
    href: `/articles/${article.id}/`,
    icon: iconFor(article.data.tags),
    title: article.data.title,
    subtitle: article.data.posted.toISOString().slice(0, 10),
  }));
---

<Layout title={entry.data.title}>
  <PageHeader label="Scraps" href="/scraps/" />
  <article class="divider flex flex-col gap-4 px-4 py-3">
    <header class="flex flex-col gap-2">
      <h1 class="text-xl font-bold">{entry.data.title}</h1>
      <ul class="flex flex-wrap gap-2">
        {
          entry.data.tags.map((tag) => (
            <li>
              <Badge label={tag} />
            </li>
          ))
        }
      </ul>
    </header>
    <div class="content">
      <Content />
    </div>
  </article>
  {
    references.length > 0 && (
      <section>
        <h2 class="px-4 py-3 text-xl font-bold">References</h2>
        <EntryList entries={references} />
      </section>
    )
  }
  <section>
    <h2 class="px-4 py-3 text-xl font-bold">Related Scraps</h2>
    <div class="px-4 pb-3">
      <Graph client:visible graph={graph} />
    </div>
  </section>
</Layout>
