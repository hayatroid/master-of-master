---
import Layout from "@/layouts/Layout.astro";
import EntryList from "@/components/EntryList";
import Profile from "@/components/Profile";
import Tabs from "@/components/Tabs";
import { iconFor } from "@/site.config";
import { getCollection } from "astro:content";

const articles = await getCollection("articles");
const entries = articles
  .toSorted((a, b) => b.data.posted.valueOf() - a.data.posted.valueOf())
  .map((entry) => ({
    href: `/articles/${entry.id}/`,
    icon: iconFor(entry.data.tags),
    title: entry.data.title,
    subtitle: entry.data.posted.toISOString().slice(0, 10),
  }));
---

<Layout>
  <Profile />
  <Tabs active="articles" />
  <EntryList entries={entries} />
</Layout>
